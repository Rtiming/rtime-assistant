# assistant-gateway runtime config. Copy to
# ~/.config/rtime-assistant/gateway.env on orangepi and adjust. No secrets
# here; the model key stays inside claude-kimi's own keyfile.
# Note: EnvironmentFile values are literal — use absolute paths, %h does not
# expand here.

# Bind to the Tailscale address only. Never bind 0.0.0.0 on a public host.
GATEWAY_BIND=127.0.0.1
GATEWAY_PORT=8765

BRAIN_ROOT=/srv/brain
CLAUDE_BIN=/usr/local/bin/claude-kimi
CLAUDE_TIMEOUT=110
# Tool turns are UNCAPPED by default (bounded by CLAUDE_TIMEOUT); a low fixed cap
# truncated multi-PDF/dedup answers. A cap is opt-in: set CLAUDE_MAX_TURNS below
# for a global cap, or per-request from the Obsidian plugin setting
# "工具轮次上限 / Tool-turn limit". Empty/0 = no cap (recommended default).
CLAUDE_MAX_TURNS=
# Per-tier *timeouts* still apply (turn count is never limited here).
# Longer timeout for duplicate checks / multi-file PDF/slide scans.
CLAUDE_INVESTIGATION_TIMEOUT=180
# Longer timeout for public web/search requests (search + fetch + final answer).
CLAUDE_WEB_TIMEOUT=170
# Runtime-error follow-ups call the model on redacted gateway logs.
CLAUDE_RUNTIME_DIAG_TIMEOUT=90
# Claude Code startup trims for the Obsidian gateway. `CLAUDE_BARE=1` is skipped
# automatically by the gateway when GATEWAY_EXTRA_ALLOWED_TOOLS contains mcp__.
CLAUDE_BARE=1
CLAUDE_NO_SESSION_PERSISTENCE=1
CLAUDE_EXCLUDE_DYNAMIC_SECTIONS=1
# Default Claude Code permission mode for tool-capable Obsidian gateway routes.
# Per-request plugin settings may override this in readonly mode. In full mode,
# the gateway forces bypassPermissions.
CLAUDE_PERMISSION_MODE=dontAsk
GATEWAY_APPROVAL_FORWARDING=1
# Default is readonly. Set to full only for explicitly trusted, owner-operated
# endpoints where Obsidian requests may organize files and update brain.
GATEWAY_ACCESS_MODE=readonly
# Public web tools for Obsidian gateway runs. This enables Claude Code built-in
# WebSearch/WebFetch plus the controlled read-only rtime-web-fetch fallback.
GATEWAY_WEB_TOOLS_ENABLED=1
# Comma-separated additional Claude Code tool names or MCP tool globs, e.g.
# mcp__browser__*,mcp__playwright__*. Only add names implemented by the live
# runner/MCP config; unknown tools are not installed by this env value.
GATEWAY_EXTRA_ALLOWED_TOOLS=

# Private Obsidian plugin release folder served at:
# http://<gateway>/api/obsidian/plugin-release/
GATEWAY_PLUGIN_RELEASE_DIR=/var/lib/rtime-assistant/plugin-release/rtime-assistant

INDEX_PYTHONPATH=/srv/rtime-assistant/packages/brain-library/src
INDEX_DB=/var/lib/rtime-assistant/brain-library/brain-library.sqlite
GATEWAY_LOG_DIR=/var/lib/rtime-assistant/assistant-gateway

# M9 memory-loop capture. Keep off by default; run-03 turns these on only after
# backup and health checks.
MEMORY_CAPTURE_ENABLED=0
MEMORY_FAILED_QUERY_LOG_ENABLED=0
MEMORY_CAPTURE_MAX_CHARS=800
# Approved-memory prompt injection. Reads only brain/memory/cards/ normal,
# non-inferred, unexpired memory-card files; review queue is never injected.
MEMORY_INJECTION_ENABLED=1
MEMORY_ROOT=/srv/brain/memory
MEMORY_INJECTION_MAX_CARDS=3
MEMORY_INJECTION_MAX_CHARS=1200
MEMORY_ACCESS_LOG_ENABLED=1
# Dynamic context sources. The registry is metadata-only JSONL; source bodies
# are read from safe brain-relative paths only when relevant to the request.
GATEWAY_CONTEXT_SOURCES_ENABLED=1
GATEWAY_CONTEXT_SOURCES_PATH=/srv/brain/_system/rtime-context-sources.jsonl
GATEWAY_CONTEXT_SOURCES_MAX_ITEMS=3
GATEWAY_CONTEXT_SOURCES_MAX_CHARS=5000
# Explicit "remember this" intents write review-queue candidates only. They do
# not merge into long-term memory/cards without a separate review flow.
GATEWAY_MEMORY_CANDIDATE_WRITE_ENABLED=1
GATEWAY_MEMORY_CANDIDATE_REVIEW_DIR=/srv/brain/memory/review-queue

# Derived relation prefetch for related/citation-review prompts.
GATEWAY_RELATIONS_PATH=/srv/brain/_indexes/relations.jsonl
GATEWAY_RELATED_PREFETCH_LIMIT=5
GATEWAY_RELATED_PREFETCH_MAX_CHARS=1200

# Obsidian prepare cache. /api/obsidian/prepare keeps short-lived resolved
# context so the next matching chat can reuse unlocks.
GATEWAY_PREPARE_CACHE_TTL=180
GATEWAY_PREPARE_CACHE_MAX=64
# Optional model prewarm during prepare. The plugin must send
# options.prewarm_model=true; prepare still returns immediately.
#
# Tool-capable Claude/Claude-wrapper routes use a single-use live stdin process:
# gateway starts the CLI early with stream-json stdin/stdout, the next matching
# chat writes the real prompt into that process, then gateway terminates it and
# replenishes a fresh blank process. This preserves model/tool quality because it
# does not lower effort, change models, remove tools, or reuse prior dialogue
# state. Set GATEWAY_LIVE_PREWARM_ENABLED=0 to fall back to the legacy short
# prewarm call.
GATEWAY_PREWARM_ENABLED=1
GATEWAY_LIVE_PREWARM_ENABLED=1
GATEWAY_LIVE_PREWARM_IDLE_SECONDS=240
# Legacy short-call prewarm TTL/timeout, still used for chat-only OpenAI routes
# and as the fallback when live stdin prewarm is disabled.
GATEWAY_PREWARM_TTL_SECONDS=240
GATEWAY_PREWARM_TIMEOUT=30

# Obsidian model catalog/cache. The plugin stores only provider/model preference;
# keys stay on the backend host and are read from env or *_FILE here.
GATEWAY_MODEL_CATALOG_PATH=/var/lib/rtime-assistant/assistant-gateway/model-catalog.json
GATEWAY_MODEL_REFRESH_TIMEOUT=8
RTIME_MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
RTIME_MOONSHOT_API_KEY_FILE=/etc/rtime-assistant/moonshot-api-key
RTIME_KIMI_OPENAI_MODELS=kimi-k2.7-code,kimi-k2.6,kimi-k2.5
RTIME_USTC_BASE_URL=https://api.llm.ustc.edu.cn/v1
RTIME_USTC_API_KEY_FILE=/etc/rtime-assistant/ustc-api-key
RTIME_USTC_MODELS=deepseek-v4-flash-ascend,qwen3.6-chat,qwen3.6-reasoner

# v0.3 session protocol (run-10). Busy requests join a FIFO queue instead of
# 503; only a full queue rejects. Streaming waiters get 排队中… heartbeats.
QUEUE_MAX=2
QUEUE_WAIT_TIMEOUT=30
QUEUE_HEARTBEAT_SECS=3
# context.history is clipped to this many chars (newest turns kept).
HISTORY_MAX_CHARS=4000
