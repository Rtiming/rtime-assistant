# Copy to /etc/rtime-assistant/docker.env on the server.
# Do not commit the real production file.

RTIME_ASSISTANT_PLATFORM=linux/arm64
RTIME_ASSISTANT_IMAGE=rtime-assistant/feishu-bridge
RTIME_ASSISTANT_IMAGE_TAG=local
INSTALL_CLAUDE_CODE=1

RTIME_ASSISTANT_UID=1000
RTIME_ASSISTANT_GID=1000
RTIME_ASSISTANT_ROOT=/srv/rtime-assistant
RTIME_ASSISTANT_STATE_DIR=/var/lib/rtime-assistant
CLAUDE_STATE_ROOT=/var/lib/rtime-assistant/claude
CLAUDE_CONFIG_JSON=/etc/rtime-assistant/.claude.json
CLAUDE_BIN=/usr/local/bin/claude
CLAUDE_CLI_PATH=/usr/local/bin/claude-rtime
CLAUDE_KIMI_KEYFILE=/run/secrets/claude-kimi-key
RTIME_CLAUDE_FALLBACK=/usr/local/bin/claude-kimi
RTIME_DEEPSEEK_CLAUDE_WRAPPER=/usr/local/bin/claude-deepseek
RTIME_QWEN_CLAUDE_WRAPPER=/usr/local/bin/claude-qwen
# Keep optional Code provider keys at /dev/null until the real key file exists.
RTIME_DEEPSEEK_API_KEY_FILE=/dev/null
RTIME_DEEPSEEK_API_KEY=
RTIME_DEEPSEEK_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
RTIME_DEEPSEEK_MODEL=deepseek-v4-pro[1m]
RTIME_DEEPSEEK_FAST_MODEL=deepseek-v4-flash
RTIME_DEEPSEEK_CODE_MODELS=deepseek-v4-pro,deepseek-v4-pro[1m],deepseek-v4-flash
RTIME_QWEN_API_KEY_FILE=/dev/null
RTIME_QWEN_API_KEY=
RTIME_QWEN_ANTHROPIC_BASE_URL=https://dashscope-intl.aliyuncs.com/apps/anthropic
RTIME_QWEN_MODEL=qwen3-coder-next
RTIME_QWEN_FAST_MODEL=qwen3-coder-flash
RTIME_QWEN_QUALITY_MODEL=qwen3-coder-plus
RTIME_QWEN_CODE_MODELS=qwen3-coder-next,qwen3-coder-plus,qwen3-coder-plus-2025-09-23,qwen3-coder-flash
RTIME_CODE_MODEL_ALIASES_JSON={"deepseek-code":"deepseek-v4-pro[1m]","ds-code":"deepseek-v4-pro[1m]","qwen-code":"qwen3-coder-next","qwen-coder":"qwen3-coder-next"}
RTIME_USTC_BASE_URL=https://api.llm.ustc.edu.cn/v1
RTIME_USTC_API_KEY_FILE=/etc/rtime-assistant/ustc-api-key
RTIME_USTC_API_KEY=
RTIME_USTC_MODELS=deepseek-v4-flash-ascend,qwen-chat,qwen-reasoner,qwen3.6-chat,qwen3.6-reasoner,smart/default,smart/reasoning
RTIME_USTC_MODEL_ALIASES_JSON={"ds":"deepseek-v4-flash-ascend","deepseek":"deepseek-v4-flash-ascend","qwen":"qwen3.6-chat","qianwen":"qwen3.6-chat","qwen-reasoner":"qwen3.6-reasoner"}
RTIME_USTC_MAX_TOKENS=8192
RTIME_USTC_TIMEOUT=180
# USTC agent-tools path: claude-ustc -> litellm service -> USTC. 1 = full agent
# tools (default); 0 = legacy tool-less inline chat in claude-rtime.
RTIME_USTC_AGENT=1
# LiteLLM protocol translator (compose service `litellm`). The upstream USTC key
# the proxy uses, and the master key claude-ustc presents to the proxy. Generate
# the master key once, e.g.: openssl rand -hex 32 (prefix sk- optional).
USTC_LLM_API_KEY=
LITELLM_MASTER_KEY=
# Pin the LiteLLM image to a digest at deploy time (PyPI litellm 1.82.7/1.82.8
# were compromised in 2025-11; lock the container the same way, never :latest).
# LITELLM_IMAGE=ghcr.io/berriai/litellm@sha256:<digest>
# Local Ollama line (srv03 Jetson, native Anthropic endpoint, minutes-slow prefill).
# RTIME_OLLAMA_BASE_URL=http://127.0.0.1:11434
# RTIME_OLLAMA_MODEL=qwen3.5:9b
# RTIME_OLLAMA_MODELS=qwen3.5:9b,qwen2.5:3b
BRAIN_ROOT=/srv/brain
FEISHU_CONFIG_JSON=/etc/rtime-assistant/feishu.json

DEFAULT_CWD=/mnt/brain
DEFAULT_MODEL=
# Complete alias map projected from packages/rtime-models/model-registry.json
# (opus/sonnet/haiku come from bot_config). KEEP IN SYNC via check-entrypoint-drift.py.
MODEL_ALIASES_JSON={"kimi":"","ds":"deepseek-v4-flash-ascend","deepseek":"deepseek-v4-flash-ascend","qwen":"qwen3.6-chat","qianwen":"qwen3.6-chat","qwen-chat":"qwen3.6-chat","qwen-reasoner":"qwen3.6-reasoner","ollama":"qwen3.5:9b","qwen-local":"qwen3.5:9b","deepseek-code":"deepseek-v4-pro[1m]","ds-code":"deepseek-v4-pro[1m]","deepseek-coder":"deepseek-v4-pro[1m]","qwen-code":"qwen3-coder-next","qwen-coder":"qwen3-coder-next"}
# This single-user Feishu production bot runs Claude Code non-interactively.
# Use bypassPermissions only with ALLOWED_USERS/ADMIN_USERS narrowed to the owner.
PERMISSION_MODE=default
# Owner-only personal library access. Keep disabled unless this Feishu bot is
# single-user, owner-authorized, and ALLOWED_USERS/ADMIN_USERS are narrowed.
FEISHU_OWNER_PERSONAL_LIBRARY_ACCESS=0
OUTPUT_STYLE=segmented
SHOW_TOOL_CALLS=0
STREAM_CHUNK_SIZE=20
STATUS_HEARTBEAT_SECONDS=6
MESSAGE_DEBOUNCE_SECONDS=2.0
MESSAGE_DEBOUNCE_MAX_MESSAGES=20
MESSAGE_DEBOUNCE_MAX_CHARS=12000
# Disable forced periodic process exits in Docker production. Docker/systemd
# healthchecks handle real failures; a fixed 4h app exit prevents 24h stability
# acceptance from being meaningful.
WATCHDOG_MAX_UPTIME_SECONDS=0

CALLBACK_BIND=127.0.0.1
CALLBACK_PORT=9981

ALLOWED_USERS=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_USERS=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALLOWED_CHATS=
REQUIRE_MENTION_IN_GROUP=1

# Optional direct provider override. The default production path uses the
# mounted CLAUDE_KIMI_KEYFILE through /usr/local/bin/claude-kimi, so these can
# stay empty unless a task intentionally bypasses the wrapper.
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=
ANTHROPIC_SMALL_FAST_MODEL=

# Optional runtime proxy for web access. Leave empty by default. If the host
# proxy is intentionally exposed to Docker, set explicit values such as
# http://host.docker.internal:7890 after adding the required Docker host-gateway
# mapping in your deployment.
RTIME_ASSISTANT_HTTP_PROXY=
RTIME_ASSISTANT_HTTPS_PROXY=
RTIME_ASSISTANT_FTP_PROXY=
RTIME_ASSISTANT_ALL_PROXY=
RTIME_ASSISTANT_NO_PROXY=localhost,127.0.0.1
