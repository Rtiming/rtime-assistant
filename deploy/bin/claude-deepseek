#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-only
# Copyright (C) 2026 rtime-assistant contributors (see NOTICE)
set -euo pipefail

export PATH="$PATH:$HOME/.npm-global/bin:/usr/local/bin:/usr/bin:/bin"

# Non-secret model DEFAULTS come from the registry-generated model-defaults.sh
# sourced next to this wrapper (REG_*). The inline ${REG_*:-literal} keeps this
# wrapper working if that file is absent; all three (registry, model-defaults.sh,
# the inline literals) are kept equal by scripts/check-entrypoint-drift.py.
# KEEP IN SYNC: packages/rtime-models/model-registry.json
DEFAULTS_FILE="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" >/dev/null 2>&1 && pwd)/model-defaults.sh"
if [ -r "$DEFAULTS_FILE" ]; then
  # shellcheck source=/dev/null
  . "$DEFAULTS_FILE"
fi

KEY="${RTIME_DEEPSEEK_API_KEY:-${DEEPSEEK_API_KEY:-}}"
KEYFILE="${RTIME_DEEPSEEK_API_KEY_FILE:-${DEEPSEEK_API_KEY_FILE:-/run/secrets/rtime-assistant/deepseek-api-key}}"
if [ -z "${KEY:-}" ] && [ -f "$KEYFILE" ]; then
  KEY="$(cat "$KEYFILE")"
fi

if [ -z "${KEY:-}" ]; then
  echo "claude-deepseek: missing DeepSeek key" >&2
  exit 1
fi

DEEPSEEK_MODEL="${RTIME_DEEPSEEK_MODEL:-${REG_DEEPSEEK_MODEL:-deepseek-v4-pro[1m]}}"
DEEPSEEK_FAST_MODEL="${RTIME_DEEPSEEK_FAST_MODEL:-${REG_DEEPSEEK_FAST_MODEL:-deepseek-v4-flash}}"

export ANTHROPIC_BASE_URL="${RTIME_DEEPSEEK_ANTHROPIC_BASE_URL:-${REG_DEEPSEEK_BASE_URL:-https://api.deepseek.com/anthropic}}"
export ANTHROPIC_AUTH_TOKEN="$KEY"
export ANTHROPIC_MODEL="$DEEPSEEK_MODEL"
export ANTHROPIC_DEFAULT_OPUS_MODEL="${RTIME_DEEPSEEK_OPUS_MODEL:-$DEEPSEEK_MODEL}"
export ANTHROPIC_DEFAULT_SONNET_MODEL="${RTIME_DEEPSEEK_SONNET_MODEL:-$DEEPSEEK_MODEL}"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="${RTIME_DEEPSEEK_HAIKU_MODEL:-$DEEPSEEK_FAST_MODEL}"
export ANTHROPIC_SMALL_FAST_MODEL="${RTIME_DEEPSEEK_SMALL_FAST_MODEL:-$DEEPSEEK_FAST_MODEL}"
export CLAUDE_CODE_SUBAGENT_MODEL="${RTIME_DEEPSEEK_SUBAGENT_MODEL:-$DEEPSEEK_FAST_MODEL}"
export CLAUDE_CODE_EFFORT_LEVEL="${RTIME_DEEPSEEK_EFFORT_LEVEL:-max}"

if [ -n "${CLAUDE_BIN:-}" ]; then
  CLI="$CLAUDE_BIN"
elif [ -x "$HOME/.npm-global/bin/claude" ]; then
  CLI="$HOME/.npm-global/bin/claude"
else
  CLI="$(command -v claude || true)"
fi

if [ -z "$CLI" ]; then
  echo "claude-deepseek: missing claude CLI" >&2
  exit 1
fi

is_deepseek_alias() {
  case "$1" in
    deepseek-code|ds-code|deepseek-coder)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

args=()
while [ "$#" -gt 0 ]; do
  case "$1" in
    --model)
      if [ "$#" -gt 1 ]; then
        if is_deepseek_alias "$2"; then
          args+=("--model" "$DEEPSEEK_MODEL")
        else
          args+=("--model" "$2")
        fi
        shift 2
      else
        args+=("$1")
        shift
      fi
      ;;
    --model=*)
      model_value="${1#--model=}"
      if is_deepseek_alias "$model_value"; then
        args+=("--model=$DEEPSEEK_MODEL")
      else
        args+=("$1")
      fi
      shift
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

if [[ "$CLI" == *.py ]]; then
  exec python3 "$CLI" "${args[@]}"
fi

exec "$CLI" "${args[@]}"
