"""Request a QQ/NapCat login QR code through the host-side selfheal daemon.

This helper is intentionally narrow. It only writes the shared request marker
that qq_selfheal.py already polls; it does not read Docker, qrcode.png, logs, or
secrets. JSON stdout is metadata-only and never contains the QR image.
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import time
from pathlib import Path
from typing import Any


DEFAULT_QR_REQUEST_FILE = "/var/lib/rtime-assistant/qq-qr-request"


def _die(message: str, code: int = 2) -> None:
    print(f"error: {message}", file=sys.stderr)
    raise SystemExit(code)


def _print(data: dict[str, Any]) -> None:
    print(json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True))


def _target_path(raw: str | None) -> Path:
    value = raw or os.getenv("RTIME_QQ_QR_REQUEST_FILE") or DEFAULT_QR_REQUEST_FILE
    value = value.strip()
    if not value:
        _die("request file path is empty")
    return Path(value).expanduser()


def _now_iso() -> str:
    return time.strftime("%Y-%m-%dT%H:%M:%S%z", time.localtime())


def request_code(args: argparse.Namespace) -> int:
    target = _target_path(args.path)
    requester = (args.requester or "feishu-model-tool").strip() or "feishu-model-tool"
    reason = (args.reason or "").strip()
    payload: dict[str, Any] = {
        "requested_at": time.time(),
        "requested_at_iso": _now_iso(),
        "requester_open_id": requester,
        "source": "rtime-qq-code",
    }
    if reason:
        # Keep the signal auditable without storing or echoing raw chat text.
        payload["reason_chars"] = len(reason)

    if not args.dry_run:
        target.parent.mkdir(parents=True, exist_ok=True)
        tmp = target.with_name(f".{target.name}.tmp")
        tmp.write_text(json.dumps(payload, ensure_ascii=False), encoding="utf-8")
        tmp.replace(target)

    _print(
        {
            "ok": True,
            "action": "request",
            "dry_run": bool(args.dry_run),
            "path": str(target),
            "source": "rtime-qq-code",
            "privacy": {
                "qr_image_returned": False,
                "requester_value_returned": False,
                "reason_text_returned": False,
            },
        }
    )
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="rtime-qq-code",
        description="Write a shared QQ QR-code request marker for qq_selfheal.",
    )
    sub = parser.add_subparsers(dest="command", required=True)
    req = sub.add_parser(
        "request",
        help="request the host-side daemon to send the latest QQ login QR code",
    )
    req.add_argument("--path", help="request marker path; defaults to RTIME_QQ_QR_REQUEST_FILE")
    req.add_argument("--requester", help="optional caller id for the local marker file")
    req.add_argument("--reason", help="optional reason; only its character count is stored")
    req.add_argument("--dry-run", action="store_true", help="validate and print metadata without writing")
    req.set_defaults(func=request_code)
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())
