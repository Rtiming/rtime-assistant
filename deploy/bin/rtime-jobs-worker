"""rtime-jobs worker launcher (operator/systemd/cron — NOT a gateway method).

Resolves the repo, puts ``packages/rtime-jobs/src`` on the path, and runs the
worker. This is the process that actually executes the heavy jobs (course
intake, index rebuild) off the chat entry. Typical use:

    rtime-jobs-worker --once                 # drain pending then exit (cron tick)
    rtime-jobs-worker --idle-exit 1800        # loop; self-exit after 30m idle (systemd)

All flags pass through to ``rtime_jobs.cli worker``.
"""

from __future__ import annotations

import os
import sys
from pathlib import Path


def _repo_root() -> Path | None:
    raw = os.environ.get("RTIME_ASSISTANT_ROOT")
    if raw and (Path(raw) / "packages" / "rtime-jobs" / "src").is_dir():
        return Path(raw)
    here = Path(__file__).resolve()
    for parent in here.parents:
        if (parent / "packages" / "rtime-jobs" / "src").is_dir():
            return parent
    return None


def main(argv: list[str] | None = None) -> int:
    repo = _repo_root()
    if repo is None:
        print('{"ok": false, "error": "cannot locate packages/rtime-jobs/src"}')
        return 2
    src = str(repo / "packages" / "rtime-jobs" / "src")
    if src not in sys.path:
        sys.path.insert(0, src)
    os.environ.setdefault("RTIME_ASSISTANT_ROOT", str(repo))
    os.environ.setdefault("PYTHONUTF8", "1")
    from rtime_jobs.cli import main as cli_main  # noqa: PLC0415

    return cli_main(["worker", *(argv if argv is not None else sys.argv[1:])])


if __name__ == "__main__":
    raise SystemExit(main())
