    "LICENSE",
    "NOTICE",
    "README.md",
    "README.zh-CN.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md",
    "AGENTS.md",
    "pyproject.toml",
    "uv.lock",
    "requirements-dev.txt",
    "module-submit.json",
    ".gitignore",
    ".gitleaks.toml",
    "packages/",
    "apps/qq-bridge/",
    "apps/feishu-bridge/",
    "apps/web-chat/",
    "apps/assistant-gateway/",
    "apps/obsidian-rtime-assistant/",
    "apps/reminder-sender/",
    "deploy/",
    "docker/",
    "compose.prod.yml",
    "compose.dev.yml",
    "docs/README.zh-CN.md",
    "docs/architecture-overview.zh-CN.md",
    "docs/reference/",
    "docs/config/",
    "docs/connect-your-own.zh-CN.md",
    "docs/instance-deploy.zh-CN.md",
    "docs/development-workflow.md",
    "tests/",
    "schemas/",
    "evals/",
    "plugins/",
    "skills/",
