{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rtime.local/schemas/docpack/chunk.schema.json",
  "title": "DocPack chunk JSONL record",
  "type": "object",
  "required": [
    "chunk_id",
    "kind",
    "text",
    "citations",
    "risks"
  ],
  "properties": {
    "chunk_id": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": ["page", "section", "concept", "example", "figure", "table", "formula", "annotation"]
    },
    "title": { "type": "string" },
    "text": { "type": "string", "minLength": 1 },
    "page_start": {
      "type": "integer",
      "minimum": 1
    },
    "page_end": {
      "type": "integer",
      "minimum": 1
    },
    "assets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "citations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": {
      "type": "number",
      "minimum": 0
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
