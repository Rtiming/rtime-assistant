{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rtime.local/schemas/docpack/citations.schema.json",
  "title": "DocPack citations",
  "type": "object",
  "required": [
    "schema_version",
    "anchors"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "anchor_id",
          "target_type",
          "source_path",
          "confidence",
          "risks"
        ],
        "properties": {
          "anchor_id": { "type": "string", "minLength": 1 },
          "target_type": {
            "type": "string",
            "enum": ["document", "page", "paragraph", "sentence", "figure", "table", "formula", "annotation", "chunk", "review"]
          },
          "source_path": { "type": "string", "minLength": 1 },
          "page": {
            "type": "integer",
            "minimum": 1
          },
          "bbox": {
            "type": "array",
            "items": { "type": "number" }
          },
          "text_span": {
            "type": "object",
            "properties": {
              "start": { "type": "integer", "minimum": 0 },
              "end": { "type": "integer", "minimum": 0 }
            }
          },
          "zotero_item": { "type": "string" },
          "zotero_annotation": { "type": "string" },
          "confidence": {
            "type": "number",
            "minimum": 0
          },
          "risks": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
