# QQ bridge (OneBot v11) — copy to deploy env. NO secrets in git.
# 权威来源 = qq_bridge/config.py 的 QQBridgeConfig.from_env() + tool_policy.py。
# 每条给出默认值(留空即默认);compose 部署时这些走 docker.env,ops 原生流走 qqbridge.env。
# 秘密类(QQ_ONEBOT_ACCESS_TOKEN 等)生产走 secret 文件,别提交实值。

# ─── 用户分级(判定顺序:黑名单 > admin > 私聊白名单 > 公开群成员) ───
# 专用小号可 DM 的 owner QQ 号(逗号/空格分隔)。空 = 拒所有私聊(绝不 allow-all)。
QQ_OWNER_IDS=
# 管理员:私聊全功能(斜杠命令 + 自选模型)。空 = 沿用 QQ_OWNER_IDS(向后兼容)。
QQ_ADMIN_IDS=
# 普通用户私聊白名单:可提问,但无斜杠命令、模型固定为实例默认。空 = 私聊仅 admin。
QQ_ALLOWED_USERS=
# 私聊开放策略:admin_allowed(默认)=仅 admin+白名单;friends=好友可问;
# friends_and_temporary=好友私聊+群临时会话可问。好友请求不会因此自动通过。
QQ_PRIVATE_ACCESS=admin_allowed
# 黑名单,优先级最高:命中一律拒(含公开群内,防捣乱)。空 = 无黑名单。
QQ_BLOCKED_USERS=

# ─── 反向 WebSocket 服务端(NapCat 主动连这里) ───
QQ_BRIDGE_WS_HOST=0.0.0.0
QQ_BRIDGE_WS_PORT=8080
QQ_BRIDGE_WS_PATH=/onebot/v11
# 可选:OneBot access token(须与 NapCat 端一致;留空 = 不校验)。生产走 secret。
QQ_ONEBOT_ACCESS_TOKEN=

# ─── 存档 / 入群审核 ───
# 原始事件全量落 JSONL 的路径。空 = 关。
QQ_BRIDGE_ARCHIVE=
# 群邀请门:reject(默认,永不自动入群) | allow(自动入) | owner(仅 owner 邀请才入)。
QQ_GROUP_INVITE_POLICY=reject
# 允许停留的群号(逗号/空格分隔)。空 = 进任何群即自动退。
QQ_GROUP_ALLOWLIST=
# 公开答疑群(学生会实例):群内任何成员 @bot 提问都答。空(默认)= 关,群消息一律拒。
# 注意:这些群号必须同时写进 QQ_GROUP_ALLOWLIST,否则防拉群逻辑会让 bot 自动退群。
QQ_PUBLIC_GROUPS=
# 群聊文本回复开头是否 @ 提问者。0(默认)=关;1=每条群文本回复都 @ 触发者。
QQ_GROUP_REPLY_AT_SENDER=0

# ─── M2 模型接入(镜像/PATH 上的 claude-rtime wrapper) ───
# claude CLI / claude-rtime wrapper 路径。空 + 不在 PATH => 模型禁用(仅 echo)。
CLAUDE_CLI_PATH=
# 模型别名(经 rtime-models 解析)。空 = wrapper 默认(kimi-code)。
DEFAULT_MODEL=
# 权限模式:default | acceptEdits | bypassPermissions | dontAsk。生产常设 bypassPermissions。
PERMISSION_MODE=default
# 模型运行目录。空 = $HOME(生产 = brain 目录)。支持 ~ 展开。
DEFAULT_CWD=
# 会话 id 存储目录(与飞书桥独立)。默认 ~/.qq-claude。
QQ_SESSIONS_DIR=~/.qq-claude
# 流式中间输出(即时"思考中" + 分段答)。1(默认)= 开;0 = 关(整段返回)。
QQ_STREAM_OUTPUT=1
# 显示具体工具/命令。0(默认)= 关(流式时只一行泛化"查阅中…");1 = 显示明细。
QQ_SHOW_TOOL_CALLS=0
# system prompt 覆盖。空 = 内置 owner 私聊 prompt。多行 prompt 建议放 compose override。
QQ_SYSTEM_PROMPT=
# 模型 CLI 的 MCP 配置(内联 JSON 或路径)。空/未设 = 无 MCP servers(跳 ~1.4s 冷启,
# QQ 经 /mnt/brain 文件系统查库)。设成 gateway JSON 以 opt-in 索引 lib_search。
QQ_MCP_CONFIG=
# 日志级别:INFO(默认)| DEBUG | …。QQ_DEBUG=1 强制 DEBUG(出模型命令/工具调用)。
QQ_LOG_LEVEL=INFO
QQ_DEBUG=0

# ─── 只读硬门(tool_policy.py;公开只读实例如学生会答疑) ───
# 1 = 写/执行/子代理工具硬禁、allowlist 收窄为只读集、权限模式强制 dontAsk。0(默认)= 关。
QQ_READ_ONLY=0

# ─── M3 多模态(入站图片/文件 + 出站媒体) ───
# 入站图片/文件下载目录(模型从这里 Read)。空 => <QQ_SESSIONS_DIR>/inbound。支持 ~ 展开。
QQ_MEDIA_DIR=
# 单个入站文件下载上限(MB)。超出的文件被拒并提示。默认 20。
QQ_MAX_DOWNLOAD_MB=20
# 是否执行模型的出站媒体指令 [[rtime-send-image:…]] / [[rtime-send-file:…]]。1(默认)= 开。
QQ_SEND_MEDIA=1
# NapCat 文件临时目录在本容器内的挂载路径(入站文件无 url,靠 get_file 落盘 + 共享挂载读取)。
# 空 => 入站文件不支持(无 url 的文件被丢弃)。
#   docker run … -v <SPIKE>/state/napcat/QQ/NapCat/temp:/napcat-files:ro -e QQ_NAPCAT_FILE_DIR=/napcat-files
QQ_NAPCAT_FILE_DIR=

# ─── 语音 STT(D;orangepi 本地 sherpa-onnx Paraformer) ───
# 本地模型目录(model.int8.onnx + tokens.txt)。空 => STT 关(语音仅确认不转写)。支持 ~ 展开。
QQ_STT_MODEL_DIR=
# NapCat OneBot HTTP 控制口 —— 用 get_record(out_format=wav) 做 SILK→WAV。默认见值。
QQ_NAPCAT_HTTP=http://127.0.0.1:3000

# ─── 风控/掉线告警(D) ───
# 掉线/断连告警 webhook(账号离线时无法经 QQ 通知,故走带外)。空 => 仅日志 + run_log。
# owner 指向自己的渠道(飞书自定义机器人 / ntfy / 通用 JSON {"text":…})。
QQ_ALERT_WEBHOOK=

# ─── 稳定性(A1)/去抖 ───
# 单次模型运行硬墙钟上限(秒)。挂死的运行被杀 + 上报而非卡住 bot。默认 600。
QQ_RUN_TIMEOUT_SECONDS=600
# 去抖:合并同一会话近乎同时的多条文本为一次运行。0(默认)= 关;部署常设 1.5 合并被拆开的问题。
QQ_DEBOUNCE_SECONDS=0
QQ_DEBOUNCE_MAX_MESSAGES=20
QQ_DEBOUNCE_MAX_CHARS=12000
# 重连补推保护:丢弃 OneBot time 早于当前 reverse-WS 连接超过 N 秒的消息事件。
# raw archive 仍会保存;只是不会回复/跑模型。0 = 关闭。默认 5。
QQ_REPLAY_GRACE_SECONDS=5
# 心跳显示账号离线后,模型跑完也不再继续 sendMsg/upload,避免离线后的超时连发。
QQ_SUPPRESS_SENDS_WHEN_OFFLINE=1

# ─── 块5 正则直答 ───
# 规则 JSON 路径(见 ops/direct-rules.example.json):固定问法(班车时刻/FAQ)命中正则
# 直接模板/数据秒回,不调模型(过 owner 门后才生效;规则失败自动回落模型)。空(默认)= 关。支持 ~ 展开。
QQ_DIRECT_RULES=

# ─── 掉线自愈守护(ops/qq_selfheal.py / qq-selfheal.service;非 bridge 进程) ───
# 守护轮询 online 状态,确认掉线 -> 自动重启 NapCat -> 把新登录二维码发到 owner 的飞书。
# 详见 ops/qqbridge.env.example。owner 的飞书 open_id(空 => 只重启不投递码)。
FEISHU_OWNER_OPEN_ID=
# 飞书自建应用凭据来源(默认复用飞书桥同一份 JSON)。也可直接给 FEISHU_APP_ID/SECRET。
FEISHU_CONFIG_JSON=$HOME/.config/rtime-assistant/feishu.json
# 轮询/防抖/冷却(秒):confirm=连续掉线满多久才动手;cooldown=两次自愈最小间隔。
SELFHEAL_POLL_SECONDS=60
SELFHEAL_OFFLINE_CONFIRM_SECONDS=120
SELFHEAL_COOLDOWN_SECONDS=900
SELFHEAL_QR_WAIT_SECONDS=45
SELFHEAL_STATUS_URL=http://127.0.0.1:3000/get_status
SELFHEAL_NAPCAT_CONTAINER=qqbr-napcat
