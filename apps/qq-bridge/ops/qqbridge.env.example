# qqbridge ops config — copy to qqbridge.env on orange pi. NO secrets in git.
# (qqbridge.env is gitignored.)
#
# NOTE (production path): the bridge now runs as a compose service. Deploy with
#   docker compose -f compose.prod.yml --env-file ~/.config/rtime-assistant/docker.env \
#     --profile qq up -d --build qq-bridge
# putting QQ_OWNER_IDS / QQ_ACCOUNT (+ any QQ_* overrides) in that docker.env. This
# ops script remains the legacy spike/native flow (QR login helper, group ops, send).

# The bot's QQ id (a DEDICATED burner — never your main; ban risk lands here).
QQ_ACCOUNT=
# 掉线自动恢复(可选):小号密码。配了它,会话失效后 NapCat 尝试用 ACCOUNT+密码
# 自动重登,免扫码。secret,只放本文件(gitignored,600),绝不进 git。空=只走扫码。
# ⚠️ 重要前提:密码登录需要账号**关闭设备锁**(QQ 安全设置)。开着设备锁时,
# 密码登录会卡在设备验证(滑块/短信)且**不会退回扫码**,反而让掉线更难恢复——
# 真机实测(2026-07-03,某号开着设备锁)即如此,已回退为纯扫码。
# 要用此项:先在手机 QQ 关掉该号的登录设备锁保护,再填密码。
NAPCAT_QUICK_PASSWORD=

# Who may DM the bot (echo only replies to these). Space/comma separated.
QQ_OWNER_IDS=

# Where the deployed code + state live on orange pi.
SPIKE_DIR=$HOME/qq-bridge-spike

# Ports (host-network NapCat reaches the bridge at 127.0.0.1:WS_PORT).
WS_PORT=8080
HTTP_PORT=3000          # NapCat OneBot HTTP control API (list/leave groups, send)
WEBUI_PORT=6099

# NapCat image (arm64 ok for orange pi).
# Do not put HTTP(S)_PROXY/ALL_PROXY here for NapCat. QQ login traffic should use
# the Orange Pi's direct domestic network; qqbridge.sh clears inherited proxy env.
NAPCAT_IMAGE=mlikiowa/napcat-docker:latest
NAPCAT_CONTAINER=qqbr-napcat

# Group-join gate: reject (default) | allow | owner
QQ_GROUP_INVITE_POLICY=reject
# Groups the bot may stay in (empty => leave any group it joins).
QQ_GROUP_ALLOWLIST=

# --- 公开答疑实例(学生会)三件套 ---
# 主线优先:学生会=主线上的一个 profile(profiles/studentunion/,RTIME_PROFILE=
# studentunion 生效),这些 env 键仅作 env-only 老部署的兼容层(profile 未启用时);
# profile 接管后提示词/只读/群/scope 全在 profile.yaml,env 只留 secrets。见
# docs/design/mainline-profiles-and-entries-2026-07.zh-CN.md 与 deploy/PROFILE-CUTOVER.md。
# 公开答疑群号(逗号分隔;空=关):群内任何成员 @bot 提问都回答,不 @ 不响应,
# 群内斜杠命令忽略;这些群必须同时在 QQ_GROUP_ALLOWLIST 里,否则 bot 自动退群。
QQ_PUBLIC_GROUPS=
# 群聊文本回复开头是否 @ 提问者。0(默认)=关;1=每条群文本回复都 @ 触发者。
QQ_GROUP_REPLY_AT_SENDER=0
# 只读硬门(0=关):1 时写/执行/子代理工具硬禁、allowlist 收窄为只读集
# (含 WebFetch/rtime-web-fetch 与 8781 只读网关 MCP),权限模式强制 dontAsk。
QQ_READ_ONLY=0
# system prompt 覆盖(空=内置 owner 私聊 prompt;多行 prompt 建议放 compose override)。
QQ_SYSTEM_PROMPT=
# 用户分级(判定顺序:黑名单 > admin > 私聊白名单 > 公开群成员):
# admin(空=沿用 QQ_OWNER_IDS):私聊全功能,含斜杠命令与自选模型。
QQ_ADMIN_IDS=
# 普通用户私聊白名单:可提问,无斜杠命令(友好拒绝)、模型固定为实例默认。
QQ_ALLOWED_USERS=
# 私聊开放策略:admin_allowed(默认)=仅 admin+白名单;friends=好友可问;
# friends_and_temporary=好友私聊+群临时会话可问。好友请求不会因此自动通过。
QQ_PRIVATE_ACCESS=admin_allowed
# 黑名单(优先级最高):命中一律拒,公开群内也拒(防捣乱)。
QQ_BLOCKED_USERS=

# --- M2 model + output ---
# Model: empty => claude-rtime wrapper default (kimi-code). /model resolves aliases.
DEFAULT_MODEL=
PERMISSION_MODE=bypassPermissions
DEFAULT_CWD=/mnt/brain
# Streaming intermediate output (思考中 + 分段答案). Tool-command detail OFF by default.
QQ_STREAM_OUTPUT=1
QQ_SHOW_TOOL_CALLS=0
# Debug: DEBUG logs (model cmd / tool calls / errors) to stdout.
QQ_DEBUG=0
# brain search: default = filesystem grep (fast). Opt-in indexed lib_search via the
# prewarmed gateway daemon (no per-message cold start): run the host service
# (deploy/systemd/user/rtime-library-gateway.service, streamable-HTTP on 127.0.0.1:8780)
# and, since the bridge uses --network host, point the CLI straight at it:
#   QQ_MCP_CONFIG={"mcpServers":{"rtime-library-gateway":{"type":"http","url":"http://127.0.0.1:8780/mcp"}}}
QQ_MCP_CONFIG=

# --- 块5 正则直答 ---
# 规则 JSON 路径(见 direct-rules.example.json):固定问法(班车时刻/FAQ)命中正则
# 直接模板/数据秒回,不调模型(owner 门之后才生效;规则失败自动回落模型)。空=关。
# compose 部署时把规则文件放进挂载卷(如 /qq-state/direct-rules.json)再指过来。
QQ_DIRECT_RULES=

# --- M3 multimodal ---
# Where inbound images/files are downloaded (model Reads them from here). Empty =>
# <QQ_SESSIONS_DIR>/inbound. Mount a writable path in the container (e.g. /qq-state/inbound).
QQ_MEDIA_DIR=
# Per-file inbound download cap (MB). Bigger files are rejected with a notice.
QQ_MAX_DOWNLOAD_MB=20
# Honor model [[rtime-send-image:…]] / [[rtime-send-file:…]] directives (outbound media).
QQ_SEND_MEDIA=1
# Inbound files: NapCat's file segment has no url and get_file only returns a path inside
# the NapCat container. Mount NapCat's file temp dir into the bridge container and set this
# to that in-container path so the bridge can read received files. Empty => files dropped.
#   docker run ... -v <SPIKE>/state/napcat/QQ/NapCat/temp:/napcat-files:ro -e QQ_NAPCAT_FILE_DIR=/napcat-files
QQ_NAPCAT_FILE_DIR=

# --- 掉线自愈 (qq_selfheal.py / qq-selfheal.service) ---
# 守护轮询 online 状态,确认掉线 -> 自动重启 NapCat -> 把新登录二维码发到 owner 的飞书。
# owner 的飞书 open_id(与飞书桥 ALLOWED_USERS 同一个)。空 => 只重启不投递。
FEISHU_OWNER_OPEN_ID=
# 飞书自建应用凭据来源(默认复用飞书桥同一份 JSON)。也可直接给 FEISHU_APP_ID/SECRET。
FEISHU_CONFIG_JSON=$HOME/.config/rtime-assistant/feishu.json
# 轮询/防抖/冷却(秒)。confirm=连续掉线满多久才动手(避开瞬断);cooldown=两次自愈最小间隔。
SELFHEAL_POLL_SECONDS=60
SELFHEAL_OFFLINE_CONFIRM_SECONDS=120
SELFHEAL_COOLDOWN_SECONDS=900
SELFHEAL_QR_WAIT_SECONDS=45
SELFHEAL_STATUS_URL=http://127.0.0.1:3000/get_status
SELFHEAL_NAPCAT_CONTAINER=qqbr-napcat
# 按需补码:在飞书私聊给 bot 发 "补码"(或 qq码/qq二维码//qqcode;普通文字或飞书富文本
# post 都可),飞书桥写一个触发文件,本守护轮询到就取当前最新登录码回推你的飞书——不用等掉线、不用 SSH。触发文件是飞书桥容器
# (无 docker)与本守护(有 docker)之间的共享文件信号,必须与飞书桥的
# RTIME_QQ_QR_REQUEST_FILE 指向**同一物理文件**:
#   host  视角(本守护读,下面这个): ~/.local/state/rtime-assistant/qq-qr-request
#   容器视角(飞书桥写,飞书 .env): /var/lib/rtime-assistant/qq-qr-request
# 两者是 compose 把 host ~/.local/state/rtime-assistant 挂到容器 /var/lib/rtime-assistant 的
# 同一目录下的同一文件。
SELFHEAL_QR_REQUEST_FILE=$HOME/.local/state/rtime-assistant/qq-qr-request
# 触发文件检查间隔(秒):比 online 轮询(60s)快,决定"发一句话到取码"的响应延迟。
SELFHEAL_QR_REQUEST_CHECK_SECONDS=4
