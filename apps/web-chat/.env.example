# web-chat (browser Q&A entry, T5b) — copy to deploy env. NO secrets in git.
# 权威来源 = web_chat/config.py 的 WebChatConfig(schema 驱动)+ profiles.py(真 loader)。
# 字段↔env↔默认值权威表:docs/config/web-chat.md(由 config schema 生成)。
# compose 部署走 --profile web(见 compose.prod.yml 的 web-chat 服务)。

# ─── HTTP 服务(design §5.3) ───
# 绑定地址。默认 127.0.0.1(仅内网自用);tailnet 开放改 0.0.0.0 并配 Tailscale ACL。
WEB_CHAT_BIND=127.0.0.1
# 监听端口。默认 8788。
WEB_CHAT_PORT=8788
# 状态目录(会话存储 sessions.json 落这里)。默认 ~/.local/state/rtime-assistant/web-chat。
RTIME_WEB_CHAT_STATE_DIR=

# ─── Profile 来源(T5b 真 loader) ───
# web-chat 扫 profiles/ 目录,列出声明了 channels.web 的 profile(下拉选择,design §5.2)。
# profiles/ 树根目录。compose 只读 bind-mount git profiles/ 到此(默认 /etc/rtime/profiles)。
# 本地开发指向仓库的 profiles/。web-chat 不绑定单个 RTIME_PROFILE(它列出全部 web profile)。
RTIME_PROFILES_ROOT=/etc/rtime/profiles
# 临时实例覆盖(可选):内联 JSON 数组或指向 JSON 文件的路径,绕过 profiles/ 树。形如:
#   RTIME_WEB_CHAT_PROFILES=[{"id":"kb","name":"知识库","read_only":true}]
# 设置后优先于 RTIME_PROFILES_ROOT。空 = 用 profiles/ 树。
RTIME_WEB_CHAT_PROFILES=
# 进程级只读硬门(单调并集):=1 强制所有 web profile 只读;=0/未设 不能降级某 profile 自身
# 的 read_only(修 env=0 降级漏洞,别回退)。studentunion profile 自身已 read_only:true。
WEB_CHAT_READ_ONLY=0

# ─── 模型接入(复用桥同名变量;镜像/PATH 上的 claude-rtime wrapper) ───
# claude CLI / claude-rtime wrapper 路径。空 + 不在 PATH => 模型禁用(仅 echo,便于本地开发)。
CLAUDE_CLI_PATH=
# 模型别名(经 rtime-models 解析)。空 = wrapper 默认(kimi-code)。
DEFAULT_MODEL=
# 权限模式:default | acceptEdits | bypassPermissions | dontAsk。
# 注意:read_only profile(如 studentunion)会在代码里强制 dontAsk,忽略此项。
PERMISSION_MODE=default
# 模型运行目录。空 = $HOME。web-chat 不挂 /mnt/brain(网关消费者),不要指向库文件系统。
DEFAULT_CWD=
# 进程默认 MCP 配置(内联 JSON 或路径)。空 = 无 MCP servers(跳冷启)。
# 注意:profile 的 channels.web.mcp_servers 会按会话覆盖此项(studentunion 指向只读
# 8781 网关);此项只是没配 web 网关的 profile 的兜底。web-chat 是 gateway-only 消费者。
WEB_CHAT_MCP_CONFIG=
# 显示具体工具/命令。0(默认)= 关(流式时只一行泛化"查阅中…");1 = 显示明细。
WEB_CHAT_SHOW_TOOL_CALLS=0
# 单次模型运行硬墙钟上限(秒)。挂死的运行被杀 + 上报。默认 600。
WEB_CHAT_RUN_TIMEOUT_SECONDS=600
# 日志级别:INFO(默认)| DEBUG。WEB_CHAT_DEBUG=1 强制 DEBUG。
WEB_CHAT_LOG_LEVEL=INFO
WEB_CHAT_DEBUG=0
