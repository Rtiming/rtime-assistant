# 飞书应用凭证（在 https://open.feishu.cn/app 创建应用后获取）
# 可直接设置 FEISHU_APP_ID/FEISHU_APP_SECRET，也可使用本机 JSON。
# FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_CONFIG_JSON=~/.config/rtime-assistant/feishu.json

# Claude 默认配置。空 DEFAULT_MODEL = 走 Kimi Code wrapper 默认（kimi-code），
# 与生产一致；canonical 默认来自 packages/rtime-models/model-registry.json。
DEFAULT_MODEL=
# Code aliases 走 Claude Code wrapper；USTC aliases 默认经 claude-ustc（LiteLLM 协议翻译，
# 全工具；RTIME_USTC_AGENT=0 退回纯聊天）；ollama/qwen-local 走本地 claude-ollama。完整别名表
# 投影自 model-registry.json（opus/sonnet/haiku 由 bot_config 提供）。
# MODEL_ALIASES_JSON='{"kimi":"","ds":"deepseek-v4-flash-ascend","deepseek":"deepseek-v4-flash-ascend","qwen":"qwen3.6-chat","qianwen":"qwen3.6-chat","qwen-chat":"qwen3.6-chat","qwen-reasoner":"qwen3.6-reasoner","ollama":"qwen3.5:9b","qwen-local":"qwen3.5:9b","deepseek-code":"deepseek-v4-pro[1m]","ds-code":"deepseek-v4-pro[1m]","deepseek-coder":"deepseek-v4-pro[1m]","qwen-code":"qwen3-coder-next","qwen-coder":"qwen3-coder-next"}'
DEFAULT_CWD=~

# 工具权限模式：default 需要确认敏感操作；bypassPermissions 只用于明确受控场景。
PERMISSION_MODE=default

# 用户可见输出：segmented 会把正文按自然段落发成多条消息，工具细节默认隐藏。
OUTPUT_STYLE=segmented
SHOW_TOOL_CALLS=0

# 输入侧防抖：生产可设为 2.0，把同一 chat 短时间内连续普通文本合成一次 Claude 调用。
# 本地默认 0 表示关闭，便于测试和调试。
# MESSAGE_DEBOUNCE_SECONDS=2.0
# MESSAGE_DEBOUNCE_MAX_MESSAGES=20
# MESSAGE_DEBOUNCE_MAX_CHARS=12000

# 看门狗主动重启窗口，单位秒。默认 14400；Docker 生产设为 0，
# 由 healthcheck/systemd 处理真实故障，避免固定周期重启。
# WATCHDOG_MAX_UPTIME_SECONDS=0

# 结构化运行日志。写到本机 state，不要放进 git 仓库。
RTIME_ASSISTANT_RUN_LOG=~/.local/state/rtime-assistant/feishu-bridge-run.jsonl

# 按需补码：owner 在飞书私聊发 "补码"(或 qq码/qq二维码//qqcode；普通文字或飞书富文本
# post 都可) → 不进模型，飞书桥往这个触发文件写一条请求，host 上的 qq_selfheal 守护轮询到
# 就取当前最新 QQ 登录码回推你的飞书。
# 更自然的“帮我发 QQ 码/小号掉线了把码发来”会进模型，由模型调用窄工具
# rtime-qq-code request 写同一个触发文件。
# 这是飞书桥容器(无 docker)与守护(有 docker)之间的共享文件信号，必须与守护的
# SELFHEAL_QR_REQUEST_FILE 指向**同一物理文件**：容器里默认 /var/lib/rtime-assistant/qq-qr-request，
# 经 compose 挂载 = host ~/.local/state/rtime-assistant/qq-qr-request(守护读的那个)。
# RTIME_QQ_QR_REQUEST_FILE=/var/lib/rtime-assistant/qq-qr-request

# 访问控制：生产必须限制 allowed open_id。群聊默认不允许，除非显式配置 ALLOWED_CHATS。
ALLOWED_USERS=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_USERS=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALLOWED_CHATS=
REQUIRE_MENTION_IN_GROUP=1

# （可选）Claude CLI 路径，生产 Docker 默认使用 claude-rtime 分流包装器。
# CLAUDE_CLI_PATH=/usr/local/bin/claude-rtime
# RTIME_CLAUDE_FALLBACK=/usr/local/bin/claude-kimi
# RTIME_DEEPSEEK_CLAUDE_WRAPPER=/usr/local/bin/claude-deepseek
# RTIME_QWEN_CLAUDE_WRAPPER=/usr/local/bin/claude-qwen
# RTIME_DEEPSEEK_API_KEY_FILE=/run/secrets/rtime-assistant/deepseek-api-key
# RTIME_QWEN_API_KEY_FILE=/run/secrets/rtime-assistant/qwen-api-key
# RTIME_USTC_BASE_URL=https://api.llm.ustc.edu.cn/v1
# RTIME_USTC_API_KEY_FILE=/run/secrets/rtime-assistant/ustc-api-key
